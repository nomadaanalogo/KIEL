  { label: 'Carpintería arquitectónica',  icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852z" /></svg>` },
  { label: 'Renovar espacios educativos', icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>` },
  { label: 'Zonas comunes',               icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>` },
  { label: 'Almacenamiento',              icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>` },
  { label: 'Otros espacios',              icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" /></svg>` },
];

const procesoCarpin = [
  { num: '01', titulo: 'Diseño', desc: 'Interpretamos el plano y proponemos materiales, acabados y estructura.' },
  { num: '02', titulo: 'Desarrollo', desc: 'Ingeniería de detalle: piezas, ensambles, tolerancias.' },
  { num: '03', titulo: 'Producción', desc: 'Fabricación en planta propia con control de calidad en cada etapa.' },
  { num: '04', titulo: 'Instalación', desc: 'Montaje en sitio. Garantizamos el resultado final.' },
];
---

<Layout
  title="Servicios de Mobiliario en Cali y Palmira"
  description="Adecuación de oficinas, mobiliario educativo, carpintería arquitectónica e institucional en Cali y Palmira. Fabricación propia en Colombia."
>

  <!-- ════════════════ HERO ════════════════ -->
  <section class="relative overflow-hidden flex items-end" style="min-height: 60vh">
    <img src="/servicios/institucional-cafeteria.webp" alt="Servicios de mobiliario Kiel en Cali y Palmira" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(2,8,22,0.94) 0%,rgba(2,8,22,0.5) 50%,rgba(2,8,22,0.1) 100%)"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 sm:px-10 pb-16" style="padding-top: 160px">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-8 h-px bg-kiel-orange"></div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-kiel-orange">Lo que hacemos</p>
      </div>
      <h1 class="font-serif text-4xl sm:text-6xl lg:text-7xl text-white leading-[1.08] mb-5 max-w-3xl">
        Mobiliario y carpintería para empresas, colegios e instituciones
      </h1>
      <p class="text-white/60 text-lg sm:text-xl max-w-xl leading-relaxed">
        Transforme sus espacios en herramientas de productividad. Solicite una visita y diseñe sin costo.
      </p>
    </div>
  </section>

  <style>
    /* mobile: nav (64px) + barra anclas (~45px) = 109px; desktop: solo nav (64px) + margen */
    [data-section], #cotizar { scroll-margin-top: 109px; }
    @media (min-width: 1024px) { [data-section], #cotizar { scroll-margin-top: 80px; } }
    .sidebar-link.active .sidebar-dot  { background: #EE9200; transform: scale(1.4); }
    .sidebar-link.active .sidebar-label { color: #EE9200; }
    .mobile-anchor.active { color: #EE9200; background: #FFF4E0; }
    .mobile-anchor.active .mob-label { max-width: 100px !important; padding-left: 6px !important; }
  </style>

  <!-- ════════════════ SIDEBAR LATERAL (desktop) ════════════════ -->
  <aside class="hidden lg:flex fixed right-6 z-40 flex-col gap-0" style="top:50%;transform:translateY(-50%)">
    {anchors.map(a => (
      <a href={`#${a.id}`} class="sidebar-link group flex items-center gap-3 py-2.5 justify-end" data-target={a.id}>
        <span class="sidebar-label text-xs font-medium text-slate-400 group-hover:text-kiel-orange transition-colors duration-200 text-right leading-tight">
          {a.label}
        </span>
        <span class="sidebar-dot w-2 h-2 rounded-full bg-slate-300 group-hover:bg-kiel-orange shrink-0 transition-all duration-200"></span>
      </a>
    ))}
  </aside>

  <!-- ════════════════ NAV ICONOS (mobile) ════════════════ -->
  <nav class="lg:hidden sticky z-40 bg-white border-b border-slate-100 shadow-sm" style="top:64px">
    <div class="flex justify-around px-2 py-1">
      {anchors.map(a => (
        <a href={`#${a.id}`} class="mobile-anchor flex items-center gap-0 rounded-full px-3 py-2 transition-all duration-300 text-slate-400" data-target={a.id}>
          <span class="[&>svg]:w-5 [&>svg]:h-5 shrink-0">
            <Fragment set:html={a.icon} />
          </span>
          <span class="mob-label text-xs font-semibold whitespace-nowrap overflow-hidden" style="max-width:0;padding-left:0;transition:max-width .35s ease,padding-left .35s ease">
            {a.label}
          </span>
        </a>
      ))}
    </div>
  </nav>

  <!-- ════════════════ ESPACIOS CORPORATIVOS ════════════════ -->
  <section id="corporativo" data-section class="bg-white py-14 sm:py-20">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <div>
          <div class="text-kiel-blue mb-3 [&>svg]:w-7 [&>svg]:h-7">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
          </div>
          <h2 class="font-serif text-4xl sm:text-5xl text-slate-900 mb-5 leading-tight">Espacios corporativos</h2>
          <p class="text-slate-500 text-lg italic mb-6 leading-snug">
            Diseño y fabricación de muebles de oficina: puestos de trabajo, escritorios, sillas, divisiones modulares, salas de juntas y recepciones.
          </p>

          <div class="flex flex-wrap gap-2 mb-8">
            {[
              { label: 'Puestos de trabajo', icon: '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3"/></svg>' },
              { label: 'Sala de juntas',     icon: '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>' },
              { label: 'Recepción',          icon: '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z"/></svg>' },
            ].map(p => (
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-700 bg-slate-100 hover:bg-kiel-blue/10 hover:text-kiel-blue px-3 py-1.5 rounded-full transition-colors">
                <Fragment set:html={p.icon} />{p.label}
              </span>
            ))}
          </div>

          <button
            class="cta-service inline-flex items-center gap-3 bg-kiel-blue hover:bg-kiel-blue-dark text-white font-semibold text-sm px-7 py-3.5 rounded-xl transition-colors"
            data-chip="0"
          >
            Quiero adecuar mi oficina
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
        </div>

        <div class="space-y-4">
          <div class="relative rounded-2xl overflow-hidden h-52 sm:h-64">
            <img src="/servicios/corporativo-openspace.webp" alt="Adecuación de oficinas y mobiliario corporativo en Cali — Kiel" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent flex items-end p-6">
              <div>
                <p class="text-white/60 text-xs font-semibold uppercase tracking-wider mb-1">Caso de éxito</p>
                <p class="text-white font-semibold text-base">Toyota · TaskUs · Amcor</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════ ESPACIOS EDUCATIVOS ════════════════ -->
  <section id="educativo" data-section class="bg-gray-50 py-14 sm:py-20">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <div class="order-2 lg:order-1 space-y-4">
          <div class="relative rounded-2xl overflow-hidden h-52 sm:h-64">
            <img src="/servicios/educativo-aula-moderna.webp" alt="Mobiliario educativo para colegios y universidades en Colombia — Kiel" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent flex items-end p-6">
              <div>
                <p class="text-white/60 text-xs font-semibold uppercase tracking-wider mb-1">Caso de éxito</p>
                <p class="text-white font-semibold text-base">Javeriana · Santo Tomás</p>
              </div>
            </div>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <div class="text-kiel-blue mb-3 [&>svg]:w-7 [&>svg]:h-7">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
          </div>
          <h2 class="font-serif text-4xl sm:text-5xl text-slate-900 mb-5 leading-tight">Espacios educativos</h2>
          <p class="text-slate-500 text-lg italic mb-6 leading-snug">
            Mobiliario para colegios, universidades y centros de formación: mesas, sillas, lockers, tableros y bibliotecas de alto tráfico.
          </p>

          <div class="flex flex-wrap gap-2 mb-8">
            {[
              { label: 'Mesas y sillas', icon: '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>' },
              { label: 'Lockers',        icon: '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>' },
              { label: 'Tableros',       icon: '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>' },
            ].map(p => (
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-700 bg-slate-100 hover:bg-kiel-blue/10 hover:text-kiel-blue px-3 py-1.5 rounded-full transition-colors">
                <Fragment set:html={p.icon} />{p.label}
              </span>
            ))}
          </div>

          <button
            class="cta-service inline-flex items-center gap-3 bg-kiel-blue hover:bg-kiel-blue-dark text-white font-semibold text-sm px-7 py-3.5 rounded-xl transition-colors"
            data-chip="2"
          >
            Quiero renovar espacios educativos
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
        </div>

      </div>
    </div>
  </section>

