<script is:inline define:vars={{ APPS_SCRIPT_URL }}>
  // ── Nav activa según sección visible ──────────────────────────────
  const navLinks = document.querySelectorAll('.sidebar-link, .mobile-anchor');
  const sections = document.querySelectorAll('[data-section]');

  function setActive(id) {
    navLinks.forEach(l => l.classList.toggle('active', l.dataset.target === id));
  }

  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => observer.observe(s));

  // ── Formulario multi-paso ──────────────────────────────────────────
  function goToStep(n) {
    [1,2,3].forEach(i => {
      document.getElementById(`step-${i}`)?.classList.toggle('hidden', i !== n);
    });
    document.getElementById('step-current').textContent = n;
    ['p1','p2','p3'].forEach((id, i) => {
      document.getElementById(id)?.classList.toggle('done', i < n);
    });
  }

  const chips = document.querySelectorAll('.chip');
  const btnNext1 = document.getElementById('btn-next-1');
  const necesidadInput = document.getElementById('necesidad-input');
  const hintOtros = document.getElementById('hint-otros');
  let selectedChip = null;

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('selected'));
      chip.classList.add('selected');
      selectedChip = chip.dataset.value;
      necesidadInput.value = selectedChip;
      btnNext1.disabled = false;
      if (hintOtros) hintOtros.classList.toggle('hidden', selectedChip !== 'Otros espacios');
    });
  });

  btnNext1?.addEventListener('click', () => goToStep(2));
  document.getElementById('btn-next-2')?.addEventListener('click', () => goToStep(3));
  document.getElementById('btn-back-2')?.addEventListener('click', () => goToStep(1));
  document.getElementById('btn-back-3')?.addEventListener('click', () => goToStep(2));

  document.getElementById('cotizar-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const form = e.target;
    const correo         = form.querySelector('[name="correo"]')?.value.trim();
    const consentimiento = form.querySelector('[name="consentimiento"]')?.checked;
    if (!correo)         { form.querySelector('[name="correo"]')?.reportValidity(); return; }
    if (!consentimiento) { form.querySelector('[name="consentimiento"]')?.reportValidity(); return; }
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin w-4 h-4 mr-2 inline" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>Enviando...';
    const data = Object.fromEntries(new FormData(form));
    try {
      const url = new URL(APPS_SCRIPT_URL);
      Object.entries(data).forEach(([k, v]) => url.searchParams.set(k, String(v)));
      await fetch(url.toString(), { mode: 'no-cors' });
      sessionStorage.setItem('kiel_lead', JSON.stringify(data));
      window.location.href = '/gracias';
    } catch {
      document.getElementById('form-error').classList.remove('hidden');
      btn.disabled = false; btn.textContent = 'Quiero que me contacten';
    }
  });

  // ── Pre-selección desde CTA de servicio ──────────────────────────
  document.querySelectorAll('.cta-service').forEach(btn => {
    btn.addEventListener('click', () => {
      const chipIndex = parseInt(btn.dataset.chip);
      document.getElementById('cotizar').scrollIntoView({ behavior: 'smooth' });
      setTimeout(() => {
        const target = document.querySelectorAll('.chip')[chipIndex];
        if (target) target.click();
      }, 600);
    });
  });

</script>
