---
import Layout from '../layouts/Layout.astro';
const WA = 'https://wa.me/573174396729?text=Hola%2C%20quiero%20cotizar%20pupitres%20y%20mobiliario%20escolar.%20%C2%BFPueden%20asesorarnos%3F';
---

<Layout
  title="Pupitres Escolares y Mobiliario Educativo en Colombia"
  description="Fábrica de pupitres escolares y mobiliario educativo en Colombia. Pupitres modernos, mesas de biblioteca, sillas y muebles para colegios y universidades. Kiel, Palmira."
>

  <section class="bg-slate-950 pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-5">
        <div class="w-8 h-px bg-kiel-orange"></div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-kiel-orange">Mobiliario educativo</p>
      </div>
      <h1 class="font-serif text-4xl sm:text-5xl text-white leading-tight mb-5 max-w-3xl">
        Fábrica de pupitres escolares y mobiliario para colegios en Colombia
      </h1>
      <p class="text-white/50 text-lg max-w-xl leading-relaxed">
        Fabricamos pupitres escolares modernos, mesas para biblioteca, sillas y muebles de almacenamiento para colegios, universidades e instituciones educativas en todo el país.
      </p>
    </div>
  </section>

  <section class="bg-white py-14 sm:py-20">
    <div class="max-w-4xl mx-auto px-6 sm:px-10">

      <div class="grid lg:grid-cols-2 gap-12 items-center mb-14">
        <div>
          <p class="text-slate-700 text-lg leading-relaxed mb-5">
            El mobiliario escolar tiene un reto que pocas categorías tienen: debe soportar el uso intensivo de cientos de estudiantes, adaptarse a diferentes edades y tamaños, y al mismo tiempo crear un ambiente que favorezca el aprendizaje.
          </p>
          <p class="text-slate-600 leading-relaxed">
            En Kiel somos fabricantes de pupitres escolares y mobiliario educativo en Colombia. Con 28 años de experiencia, producimos desde pupitres individuales hasta el equipamiento completo de aulas, bibliotecas y zonas de estudio.
          </p>
        </div>
        <img
          src="/hero/colegio3.webp"
          alt="Aula escolar con pupitres modernos y mobiliario educativo fabricado por Kiel en Colombia"
          class="rounded-2xl object-cover w-full aspect-video"
          loading="lazy"
        />
      </div>

      <div class="bg-slate-50 rounded-2xl p-8 mb-14">
        <h2 class="font-serif text-2xl text-slate-900 mb-6">Mobiliario escolar que fabricamos</h2>
        <ul class="grid sm:grid-cols-2 gap-4">
          {[
            'Pupitres escolares individuales y modernos',
            'Pupitres escolares con almacenamiento integrado',
            'Mesas y sillas para aula universitaria',
            'Mesas para biblioteca y sala de lectura',
            'Muebles de almacenamiento para aulas y colegios',
            'Lockers y armarios escolares',
            'Mobiliario para preescolar y jardín infantil',
            'Sillas y mesas para fábrica de sillas para colegios',
          ].map(item => (
            <li class="flex items-start gap-3 text-slate-700">
              <span class="w-5 h-5 rounded-full bg-kiel-orange/15 text-kiel-orange flex items-center justify-center shrink-0 mt-0.5">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-center mb-14">
        <img
          src="/servicios/educativo-aula-moderna.webp"
          alt="Aula moderna con pupitres escolares y mobiliario educativo — proyecto Kiel en Colombia"
          class="rounded-2xl object-cover w-full aspect-video"
          loading="lazy"
        />
        <div>
          <h2 class="font-serif text-2xl text-slate-900 mb-5">Fabricantes de pupitres escolares con experiencia en colegios colombianos</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Hemos equipado colegios, universidades e instituciones educativas en Cali, Palmira y en todo Colombia. Nuestros pupitres escolares modernos se fabrican en tablero de alta resistencia, con estructuras metálicas reforzadas para soportar el uso diario intensivo.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Cotizamos por unidad o por proyecto completo. Si necesita amueblar un aula, varias aulas o toda la institución, le presentamos propuesta técnica y económica sin costo.
          </p>
        </div>
      </div>

    </div>
  </section>

  <section class="bg-kiel-orange py-14 sm:py-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 text-center">
      <h2 class="font-serif text-3xl sm:text-4xl text-white mb-4">¿Necesita pupitres o mobiliario escolar?</h2>
      <p class="text-white/85 mb-8 max-w-md mx-auto leading-relaxed">
        Cuéntenos cuántos pupitres necesita, para qué edades y el presupuesto disponible. Le cotizamos de inmediato.
      </p>
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-white text-kiel-orange font-semibold px-8 py-4 rounded-xl hover:bg-orange-50 transition-colors text-base"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.858L.057 23.272a.75.75 0 00.92.92l5.517-1.448A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.896 0-3.68-.497-5.229-1.367l-.374-.214-3.876 1.016 1.035-3.768-.234-.389A9.946 9.946 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        Cotizar pupitres ahora
      </a>
    </div>
  </section>

</Layout>
