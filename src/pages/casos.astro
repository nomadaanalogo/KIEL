---
import Layout from '../layouts/Layout.astro';

const logos = [
  { src: '/logos/toyota-seeklogo.svg',  alt: 'Toyota' },
  { src: '/logos/Ecopetrol_Logo_0.svg', alt: 'Ecopetrol' },
  { src: '/logos/bavaria.webp',          alt: 'Bavaria' },
  { src: '/logos/Corona Colombia.svg',  alt: 'Corona' },
  { src: '/logos/taskus.webp',  alt: 'TaskUs' },
  { src: '/logos/motul-logo-1.svg',     alt: 'Motul' },
];

const galeria = [
  { src: '/casos/cafeteria.webp',       alt: 'Cafetería institucional' },
  { src: '/casos/cafeteria2.webp',      alt: 'Cafetería institucional' },
  { src: '/casos/cafeteria4.webp',      alt: 'Cafetería — comedor institucional' },
  { src: '/casos/cafeteria6.webp',      alt: 'Mobiliario para cafetería' },
  { src: '/casos/peluqueria.webp',      alt: 'Peluquería — carpintería a medida' },
  { src: '/casos/peluqueria2.webp',     alt: 'Peluquería — mobiliario Kiel' },
  { src: '/casos/sunrise-cargo.webp',   alt: 'Sunrise Cargo Colombia' },
  { src: '/casos/alcaldia-cali.webp',   alt: 'Alcaldía de Cali' },
  { src: '/casos/san-buenaventura.webp',alt: 'Universidad San Buenaventura' },
  { src: '/casos/terminal-cali.webp',   alt: 'Terminal de Transportes Cali' },
  { src: '/casos/colegio-andes.webp',   alt: 'Colegio Los Andes' },
  { src: '/casos/estanteria-caso.webp', alt: 'Sistema de almacenamiento' },
  { src: '/casos/proyecto1.webp',       alt: 'Proyecto Kiel' },
  { src: '/casos/proyecto2.webp',       alt: 'Proyecto Kiel' },
  { src: '/casos/proyecto3.webp',       alt: 'Proyecto Kiel' },
  { src: '/casos/proyecto4.webp',       alt: 'Proyecto Kiel' },
  { src: '/casos/proyecto5.webp',       alt: 'Proyecto Kiel' },
];

const stats = [
  { num: '28',  label: 'años de experiencia' },
  { num: '+200',label: 'proyectos entregados' },
  { num: '+50', label: 'clientes activos' },
  { num: '5',   label: 'líneas de servicio' },
];

const clientes: Record<string, string[]> = {
  'Palmira': ['Mapura', 'Oxígenos del Sur', 'Colegio Montessori', 'Colegio Santo Tomás', 'Padel Black Social Club', 'Yoglat'],
  'Cali': ['Universidad Javeriana', 'Universidad Santiago de Cali', 'Universidad San Buenaventura', 'Colegio Berchmans'],
  'Tuluá · Buga': ['Agrohacienda La Martina', 'Colombo Farmacéutica', 'Policía Buga'],
};
---

<Layout
  title="Proyectos de Mobiliario y Diseño de Espacios en Colombia"
  description="Más de 200 proyectos entregados. Toyota, Ecopetrol, Bavaria, Javeriana y más de 50 clientes en el Valle del Cauca. Kiel, fábrica de muebles en Palmira."
>

  <!-- ════════════════ HERO ════════════════ -->
  <section class="relative overflow-hidden flex items-end" style="min-height:52vh">
    <img src="/hero/saladejuntas.webp" alt="Proyectos Kiel — mobiliario corporativo y educativo en Colombia" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(2,8,22,0.93) 0%,rgba(2,8,22,0.45) 60%,rgba(2,8,22,0.08) 100%)"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 sm:px-10 pb-14 pt-36">
      <div class="flex items-center gap-4 mb-5">
        <div class="w-8 h-px bg-kiel-orange"></div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-kiel-orange">Lo que hemos hecho</p>
      </div>
      <h1 class="font-serif text-4xl sm:text-6xl text-white leading-[1.08] mb-4 max-w-2xl">
        Espacios que hablan por sí solos
      </h1>
      <p class="text-white/55 text-lg max-w-lg leading-relaxed">
        28 años transformando oficinas, colegios y espacios institucionales en todo el Valle del Cauca.
      </p>
    </div>
  </section>

  <!-- ════════════════ STATS ════════════════ -->
  <section class="bg-kiel-blue">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-white/10">
        {stats.map(s => (
          <div class="py-8 sm:py-10 px-6 sm:px-8 text-center">
            <p class="font-serif text-3xl sm:text-4xl font-bold text-white mb-1">{s.num}</p>
            <p class="text-white/55 text-xs sm:text-sm uppercase tracking-wider">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════ GALERÍA ════════════════ -->
  <section class="bg-white py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">

      <div class="mb-10">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-kiel-orange mb-2">Nuestro trabajo</p>
        <h2 class="font-serif text-3xl sm:text-4xl text-slate-900">Así lucen los espacios</h2>
      </div>

      <!-- Grid asimétrico: primer item grande, resto pequeños -->
      <style>
        .gallery-grid { grid-auto-rows: 120px; }
        @media (min-width: 640px)  { .gallery-grid { grid-auto-rows: 160px; } }
        @media (min-width: 1024px) { .gallery-grid { grid-auto-rows: 210px; } }
      </style>
      <div class="gallery-grid grid grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-3">
        {galeria.map((foto, i) => (
          <button
            class={`lb-trigger group relative overflow-hidden rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-kiel-orange${i === 0 ? ' col-span-2 row-span-2' : ''}`}
            data-index={i}
            aria-label={`Ver foto: ${foto.alt}`}
          >
            <img
              src={foto.src}
              alt={foto.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading={i < 5 ? 'eager' : 'lazy'}
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
              <svg class="w-7 h-7 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
              </svg>
            </div>
          </button>
        ))}
      </div>

    </div>
  </section>

  <!-- ════════════════ LIGHTBOX ════════════════ -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[100] hidden items-center justify-center"
    style="background:rgba(2,6,18,0.93);backdrop-filter:blur(8px)"
    role="dialog"
    aria-modal="true"
    aria-label="Galería de proyectos"
  >
    <!-- Botón cerrar -->
    <button id="lb-close" class="absolute top-4 right-4 sm:top-6 sm:right-6 text-white/60 hover:text-white transition-colors p-2 z-10" aria-label="Cerrar">
      <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Contador -->
    <p id="lb-counter" class="absolute top-5 left-1/2 -translate-x-1/2 text-white/50 text-sm font-medium tabular-nums"></p>

    <!-- Imagen -->
    <div class="relative flex items-center justify-center w-full h-full px-14 sm:px-20 py-16">
      <img id="lb-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl select-none" style="max-height:85vh" draggable="false" />
    </div>

    <!-- Prev -->
    <button id="lb-prev" class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-3" aria-label="Anterior">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
      </svg>
    </button>

    <!-- Next -->
    <button id="lb-next" class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-3" aria-label="Siguiente">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
      </svg>
    </button>
  </div>

  <script type="application/json" id="lb-data" is:inline set:html={JSON.stringify(galeria)}></script>

  <script is:inline>
    const fotos = JSON.parse(document.getElementById('lb-data').textContent);
    const lb     = document.getElementById('lightbox');
    const img    = document.getElementById('lb-img');
    const counter= document.getElementById('lb-counter');
    const btnClose = document.getElementById('lb-close');
    const btnPrev  = document.getElementById('lb-prev');
    const btnNext  = document.getElementById('lb-next');
    let current = 0;
    let touchStartX = 0;

    function show(i) {
      current = (i + fotos.length) % fotos.length;
      img.src = fotos[current].src;
      img.alt = fotos[current].alt;
      counter.textContent = `${current + 1} / ${fotos.length}`;
    }

    function open(i) {
      show(i);
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.lb-trigger').forEach(btn => {
      btn.addEventListener('click', () => open(+btn.dataset.index));
    });

    btnClose.addEventListener('click', close);
    btnPrev.addEventListener('click', () => show(current - 1));
    btnNext.addEventListener('click', () => show(current + 1));

    lb.addEventListener('click', e => { if (e.target === lb) close(); });

    document.addEventListener('keydown', e => {
      if (!lb.classList.contains('flex')) return;
      if (e.key === 'Escape')      close();
      if (e.key === 'ArrowLeft')   show(current - 1);
      if (e.key === 'ArrowRight')  show(current + 1);
    });

    lb.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend',   e => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) dx < 0 ? show(current + 1) : show(current - 1);
    });
  </script>

  <!-- Datos para el lightbox -->
  <script id="lb-data" type="application/json" is:inline>
    {JSON.stringify(galeria)}
  </script>

  <!-- ════════════════ LOGOS CLIENTES ════════════════ -->
  <section class="bg-slate-50 py-16 sm:py-20 border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 text-center">

      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-slate-400 mb-3">Empresas que confían en Kiel</p>
      <h2 class="font-serif text-3xl sm:text-4xl text-slate-900 mb-14">Clientes que nos respaldan</h2>

      <div class="grid grid-cols-3 sm:grid-cols-6 gap-8 items-center justify-items-center">
        {logos.map(l => (
          <div class="group flex items-center justify-center w-full h-14">
            <img
              src={l.src}
              alt={l.alt}
              class="max-h-10 w-auto max-w-full object-contain grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-400"
            />
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ════════════════ LISTA DE CLIENTES ════════════════ -->
  <section class="bg-white py-16 sm:py-20 border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">

      <div class="mb-10">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-kiel-orange mb-2">También han confiado en nosotros</p>
        <h2 class="font-serif text-3xl sm:text-4xl text-slate-900">Presencia en el Valle del Cauca</h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-10 lg:gap-16">
        {Object.entries(clientes).map(([ciudad, lista]) => (
          <div>
            <div class="flex items-center gap-3 mb-5">
              <div class="w-5 h-px bg-kiel-orange"></div>
              <p class="text-xs font-bold uppercase tracking-widest text-kiel-blue">{ciudad}</p>
            </div>
            <ul class="space-y-3">
              {lista.map(c => (
                <li class="flex items-center gap-3 text-slate-600 text-sm">
                  <span class="w-1 h-1 rounded-full bg-kiel-orange shrink-0"></span>
                  {c}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ════════════════ CTA ════════════════ -->
  <section class="bg-kiel-blue py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-6 sm:px-10 text-center">
      <h2 class="font-serif text-3xl sm:text-4xl text-white mb-4">¿Su empresa podría ser la próxima?</h2>
      <p class="text-white/60 text-lg mb-8 leading-relaxed">Contáctenos y diseñamos sin costo una propuesta para su espacio.</p>
      <a
        href="https://wa.me/573174396729?text=Hola%20Kiel%2C%20vengo%20de%20la%20p%C3%A1gina%20web%20y%20me%20gustar%C3%ADa%20cotizar%20un%20proyecto."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-kiel-orange hover:bg-kiel-orange-dark text-white font-semibold px-8 py-4 rounded-xl transition-colors"
      >
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.855L.057 23.882a.5.5 0 00.606.63l6.208-1.63A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.882a9.875 9.875 0 01-5.031-1.376l-.36-.214-3.733.979.997-3.645-.235-.374A9.861 9.861 0 012.118 12C2.118 6.53 6.53 2.118 12 2.118S21.882 6.53 21.882 12 17.47 21.882 12 21.882z"/>
        </svg>
        Cotizar por WhatsApp
      </a>
    </div>
  </section>

</Layout>
