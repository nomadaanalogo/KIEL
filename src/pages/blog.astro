---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    slug: '/mobiliario-oficina',
    categoria: 'Espacios corporativos',
    titulo: 'Mobiliario para oficina: diseñado y fabricado a su medida',
    resumen: 'No vendemos catálogo. Diseñamos y producimos cada pieza según las dimensiones, el uso y la identidad visual de su empresa. Puestos de trabajo, escritorios, salas de juntas y almacenamiento.',
    fecha: '4 min de lectura',
    imagen: '/hero/oficina1.webp',
    color: '#0065AD',
  },
  {
    slug: '/escritorios-gerenciales',
    categoria: 'Mobiliario corporativo',
    titulo: 'Escritorios gerenciales modernos fabricados a medida',
    resumen: 'El escritorio de un directivo comunica autoridad, orden y el nivel de detalle que su empresa le da a cada espacio. Fabricamos en MDF o aglomerado, con acabados en melamina, laca o chapa natural.',
    fecha: '3 min de lectura',
    imagen: '/nosotros/escritorio.webp',
    color: '#0065AD',
  },
  {
    slug: '/sillas-giratorias-ergonomicas-oficina',
    categoria: 'Mobiliario de oficina',
    titulo: 'Sillas giratorias ergonómicas para oficina: qué considerar antes de comprar',
    resumen: 'Una silla de oficina es donde cada colaborador pasa entre 6 y 9 horas al día. Le ayudamos a elegir el modelo correcto según el perfil de uso, el presupuesto y la estética del espacio.',
    fecha: '4 min de lectura',
    imagen: '/hero/sillas.webp',
    color: '#0065AD',
  },
  {
    slug: '/divisiones-para-oficina-modulares-colombia',
    categoria: 'Adecuación de espacios',
    titulo: 'Divisiones para oficina modulares en Colombia',
    resumen: 'Separamos espacios de trabajo sin obras civiles: tablero, vidrio o sistemas mixtos. Una división bien diseñada define zonas, reduce el ruido y le da identidad al espacio.',
    fecha: '3 min de lectura',
    imagen: '/servicios/corporativo-openspace.webp',
    color: '#0065AD',
  },
  {
    slug: '/mobiliario-para-cafeterias-y-espacios-comunes',
    categoria: 'Espacios comunes',
    titulo: 'Mobiliario para cafeterías y comedores corporativos',
    resumen: 'Los espacios de descanso son cada vez más estratégicos. Fabricamos mesas, sillas, mostradores y barras para cafeterías corporativas y comedores institucionales de cualquier escala.',
    fecha: '3 min de lectura',
    imagen: '/casos/cafeteria.webp',
    color: '#059669',
  },
  {
    slug: '/gondolas-o-estantes-para-supermercados',
    categoria: 'Almacenamiento y exhibición',
    titulo: 'Góndolas y estantes para supermercados en Colombia',
    resumen: 'La estantería define el flujo de compra y la exhibición del producto. Fabricamos góndolas, estantes y muebles de exhibición a las medidas exactas de su espacio comercial.',
    fecha: '3 min de lectura',
    imagen: '/casos/estanteria-caso.webp',
    color: '#92400E',
  },
  {
    slug: '/pupitres-y-muebles-de-almacenamiento-para-colegios',
    categoria: 'Mobiliario educativo',
    titulo: 'Fábrica de pupitres escolares y mobiliario para colegios',
    resumen: 'Somos fabricantes de pupitres escolares modernos, mesas para biblioteca y mobiliario educativo completo para colegios, universidades e instituciones educativas en Colombia.',
    fecha: '4 min de lectura',
    imagen: '/hero/colegio3.webp',
    color: '#059669',
  },
  {
    slug: '/auditorios-teatros-y-estadios-fabricantes',
    categoria: 'Auditorios y eventos',
    titulo: 'Sillas para auditorio y teatro en Colombia',
    resumen: 'Equipamos auditorios, teatros, iglesias y salas de capacitación con sillas abatibles, fijas y sistemas de gradería. También fabricamos tarimas, atriles y mesas de ponentes.',
    fecha: '3 min de lectura',
    imagen: '/servicios/educativo-sala-universitaria.webp',
    color: '#7C3AED',
  },
  {
    slug: '/servicios#carpinteria',
    categoria: 'Carpintería arquitectónica',
    titulo: 'Carpintería arquitectónica: qué es y por qué marca la diferencia en su proyecto',
    resumen: 'No toda la madera es igual. La carpintería arquitectónica integra elementos fijos al espacio — closets, cocinas, mesones, bibliotecas empotradas — con precisión milimétrica y acabados que hacen parte permanente de la construcción.',
    fecha: '6 min de lectura',
    imagen: '/hero/carpinteria-arquitectonica.webp',
    color: '#92400E',
  },
];
---

<Layout
  title="Blog de Mobiliario y Diseño de Espacios"
  description="Artículos sobre mobiliario corporativo, diseño de espacios educativos y carpintería arquitectónica en Colombia."
>

  <!-- ════════════════ HERO ════════════════ -->
  <section class="bg-slate-950 pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-5">
        <div class="w-8 h-px bg-kiel-orange"></div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-kiel-orange">Ideas y tendencias</p>
      </div>
      <h1 class="font-serif text-4xl sm:text-6xl text-white leading-tight mb-4">
        Blog de mobiliario y diseño de espacios
      </h1>
      <p class="text-white/50 text-lg max-w-lg leading-relaxed">
        Consejos, tendencias y referencias para transformar tus espacios.
      </p>
    </div>
  </section>

  <!-- ════════════════ POSTS ════════════════ -->
  <section class="bg-gray-50 py-14 sm:py-20">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">

      <!-- Post destacado (primero) -->
      <a href={posts[0].slug} class="group block bg-white rounded-2xl overflow-hidden border border-slate-100 hover:border-slate-200 hover:shadow-lg transition-all duration-300 mb-6">
        <div class="grid lg:grid-cols-2">
          <div class="relative overflow-hidden h-64 lg:h-auto min-h-64">
            <img src={posts[0].imagen} alt={posts[0].titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0" style="background:linear-gradient(to right,transparent 60%,rgba(255,255,255,0.05) 100%)"></div>
          </div>
          <div class="p-8 sm:p-10 flex flex-col justify-center">
            <span class="inline-block text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-5 w-fit" style={`background:${posts[0].color}18; color:${posts[0].color}`}>
              {posts[0].categoria}
            </span>
            <h2 class="font-serif text-2xl sm:text-3xl text-slate-900 leading-snug mb-4 group-hover:text-kiel-blue transition-colors">
              {posts[0].titulo}
            </h2>
            <p class="text-slate-500 text-sm leading-relaxed mb-6">{posts[0].resumen}</p>
            <div class="flex items-center gap-4 text-xs text-slate-400">
              <span>{posts[0].fecha}</span>
            </div>
          </div>
        </div>
      </a>

      <!-- Grid de posts secundarios -->
      <div class="grid sm:grid-cols-2 gap-6">
        {posts.slice(1).map(post => (
          <a href={post.slug} class="group bg-white rounded-2xl overflow-hidden border border-slate-100 hover:border-slate-200 hover:shadow-lg transition-all duration-300 flex flex-col">
            <div class="relative overflow-hidden h-52">
              <img src={post.imagen} alt={post.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <span class="inline-block text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4 w-fit" style={`background:${post.color}18; color:${post.color}`}>
                {post.categoria}
              </span>
              <h2 class="font-serif text-xl text-slate-900 leading-snug mb-3 group-hover:text-kiel-blue transition-colors flex-1">
                {post.titulo}
              </h2>
              <p class="text-slate-500 text-sm leading-relaxed mb-5 line-clamp-2">{post.resumen}</p>
              <div class="flex items-center gap-4 text-xs text-slate-400">
                <span>{post.fecha}</span>
              </div>
            </div>
          </a>
        ))}
      </div>


    </div>
  </section>

</Layout>
