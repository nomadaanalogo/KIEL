---
import Layout from '../layouts/Layout.astro';
const WA = '573174396729';
---

<Layout
  title="¡Gracias por contactarnos! — Kiel"
  description="Recibimos tu solicitud. Un asesor de Kiel te contactará en menos de 24 horas."
  noindex={true}
>

  <section class="min-h-screen flex items-center justify-center bg-slate-50 px-6 py-20">
    <div class="max-w-lg w-full text-center">

      <!-- Checkmark animado -->
      <div class="flex justify-center mb-8">
        <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center" style="animation: pop 0.4s cubic-bezier(0.175,0.885,0.32,1.275) both">
          <svg class="w-10 h-10 text-green-500" style="animation: draw 0.5s 0.3s ease both" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>

      <p class="text-sm font-semibold text-kiel-blue uppercase tracking-widest mb-3">Solicitud recibida</p>
      <h1 class="font-serif text-4xl sm:text-5xl text-slate-900 mb-4 leading-tight">¡Gracias por<br>escribirnos!</h1>
      <p class="text-slate-500 text-lg leading-relaxed mb-10">
        Un asesor de Kiel revisará tu solicitud y te contactará en <strong class="text-slate-700">menos de 24 horas</strong>.
      </p>

      <!-- CTA WhatsApp con info pre-llenada -->
      <a id="wa-btn" href={`https://wa.me/${WA}`} target="_blank" rel="noopener"
        class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1dbd5a] text-white font-semibold text-base px-8 py-4 rounded-2xl transition-colors shadow-lg shadow-green-200 mb-6">
        <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Escribir por WhatsApp
      </a>

      <br />
      <a href="/" class="text-sm text-slate-400 hover:text-kiel-blue transition-colors underline underline-offset-4">
        Volver al inicio
      </a>

    </div>
  </section>

  <style>
    @keyframes pop {
      0%   { transform: scale(0); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes draw {
      0%   { stroke-dasharray: 0 50; opacity: 0; }
      100% { stroke-dasharray: 50 0; opacity: 1; }
    }
  </style>

  <script is:inline define:vars={{ WA }}>
    const raw = sessionStorage.getItem('kiel_lead');
    if (raw) {
      try {
        const d = JSON.parse(raw);
        const lineas = [
          '🪑 Hola Kiel, vengo de la página web y quiero cotizar.',
          '',
          d.necesidad   ? `📌 Necesidad: ${d.necesidad}`     : '',
          d.nombre      ? `👤 Nombre: ${d.nombre}`           : '',
          d.empresa     ? `🏢 Empresa: ${d.empresa}`         : '',
          d.telefono    ? `📞 Teléfono: ${d.telefono}`       : '',
          d.cargo       ? `💼 Cargo: ${d.cargo}`             : '',
          d.descripcion ? `📝 Descripción: ${d.descripcion}` : '',
        ].filter(Boolean);

        const msg = encodeURIComponent(lineas.join('\n'));
        const btn = document.getElementById('wa-btn');
        if (btn) btn.href = `https://wa.me/${WA}?text=${msg}`;
      } catch {}
    }
  </script>

</Layout>
