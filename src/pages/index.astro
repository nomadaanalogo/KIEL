<script is:inline define:vars={{ APPS_SCRIPT_URL }}>
  const form           = document.getElementById('cotizar-form');
  const necesidadInput = document.getElementById('necesidad-input');
  const stepCurrentEl  = document.getElementById('step-current');
  const chips          = document.querySelectorAll('.chip');
  const btnNext1       = document.getElementById('btn-next-1');
  const btnBack2       = document.getElementById('btn-back-2');
  const btnNext2       = document.getElementById('btn-next-2');
  const btnBack3       = document.getElementById('btn-back-3');
  const submitBtn      = document.getElementById('submit-btn');
  const successMsg     = document.getElementById('form-success');
  const errorMsg       = document.getElementById('form-error');

  const stepEls = { 1: document.getElementById('step-1'), 2: document.getElementById('step-2'), 3: document.getElementById('step-3') };
  const pillEls = { 1: document.getElementById('p1'),     2: document.getElementById('p2'),     3: document.getElementById('p3')     };

  function goToStep(n) {
    Object.values(stepEls).forEach(el => el?.classList.add('hidden'));
    stepEls[n]?.classList.remove('hidden');
    Object.entries(pillEls).forEach(([key, pill]) => {
      Number(key) <= n ? pill?.classList.add('done') : pill?.classList.remove('done');
    });
    if (stepCurrentEl) stepCurrentEl.textContent = String(n);
  }

  btnNext1?.addEventListener('click', () => goToStep(2));
  btnBack2?.addEventListener('click', () => goToStep(1));
  btnNext2?.addEventListener('click', () => goToStep(3));
  btnBack3?.addEventListener('click', () => goToStep(2));

  chips.forEach((btn) => {
    btn.addEventListener('click', () => {
      chips.forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      if (necesidadInput) necesidadInput.value = btn.dataset.value ?? '';
      if (btnNext1) btnNext1.disabled = false;
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nombre   = form.querySelector('[name="nombre"]')?.value.trim();
    const empresa  = form.querySelector('[name="empresa"]')?.value.trim();
    const telefono = form.querySelector('[name="telefono"]')?.value.trim();
    if (!nombre || !empresa || !telefono) { form.querySelector('[name="nombre"]')?.reportValidity(); return; }

    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Enviando...'; }
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const payload = {
      fecha:       new Date().toLocaleString('es-CO', { timeZone: 'America/Bogota' }),
      necesidad:   necesidadInput?.value || '',
      descripcion: form.querySelector('[name="descripcion"]')?.value.trim() || '',
      nombre, empresa, telefono,
      cargo:       form.querySelector('[name="cargo"]')?.value.trim() || '',
      correo:      form.querySelector('[name="correo"]')?.value.trim() || '',
    };

    try {
      await fetch(APPS_SCRIPT_URL, { method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      form.reset();
      chips.forEach(b => b.classList.remove('selected'));
      if (necesidadInput) necesidadInput.value = '';
      if (btnNext1) btnNext1.disabled = true;
      Object.values(stepEls).forEach(el => el?.classList.add('hidden'));
      successMsg?.classList.remove('hidden');
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Quiero que me contacten'; }
    }
  });
</script>
