---
import Layout from '../layouts/Layout.astro';

const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/PENDIENTE/exec';

const heroSlides = [
  { src: '/hero/javerianacali.webp',             alt: 'Proyecto Javeriana Cali — mobiliario universitario Kiel' },
  { src: '/hero/carpinteria-arquitectonica.webp', alt: 'Carpintería arquitectónica Kiel Palmira' },
  { src: '/hero/saladejuntas.webp',              alt: 'Sala de juntas equipada por Kiel en Cali' },
  { src: '/hero/colegio3.webp',                  alt: 'Mobiliario educativo para colegios en Colombia — Kiel' },
  { src: '/hero/sillas.webp',                    alt: 'Sillas y mobiliario colectivo para instituciones — Kiel' },
];

const chipOpciones = [
  {
    label: 'Adecuar oficinas',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
  },
  {
    label: 'Carpintería arquitectónica',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852z" /></svg>`,
  },
  {
    label: 'Renovar espacios educativos',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
  },
  {
    label: 'Mobiliario institucional',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>`,
  },
  {
    label: 'Almacenamiento',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>`,
  },
  {
    label: 'Otro',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" /></svg>`,
  },
];

const servicios = [
  {
    titulo: 'Adecuar oficinas',
    desc: 'Espacios corporativos que mejoran la productividad y la imagen de tu empresa.',
    href: '/servicios#corporativos',
    img: '/hero/oficina3.webp',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
  },
  {
    titulo: 'Renovar o adecuar espacios educativos',
    desc: 'Mobiliario diseñado para resistir el uso intensivo de colegios y universidades.',
    href: '/servicios#educativos',
    img: '/hero/colegio2.webp',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
  },
  {
    titulo: 'Carpintería arquitectónica',
    desc: 'Convertimos diseños complejos en realidades construidas con precisión.',
    href: '/servicios#carpinteria',
    img: '/hero/mesa-diseno.webp',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852z" /></svg>`,
  },
  {
    titulo: 'Equipar espacios colectivos',
    desc: 'Soluciones para colectividades, entidades públicas y organizaciones de gran escala.',
    href: '/servicios#institucional',
    img: '/hero/oficina1.webp',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>`,
  },
  {
    titulo: 'Optimizar almacenamiento',
    desc: 'Aprovecha cada metro cuadrado disponible con soluciones a la medida.',
    href: '/servicios#almacenamiento',
    img: '/hero/estanteria2.webp',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>`,
  },
];

const pasos = [
  { num: '01', titulo: 'Escuchamos', desc: 'Entendemos quién usará el espacio y qué necesita lograr.' },
  { num: '02', titulo: 'Diseñamos', desc: 'Convertimos esa necesidad en una propuesta funcional y a la medida.' },
  { num: '03', titulo: 'Fabricamos', desc: 'Producción propia, con control total de calidad y materiales.' },
  { num: '04', titulo: 'Instalamos', desc: 'Ejecución completa en sitio. Llegamos hasta el final.' },
  { num: '05', titulo: 'Acompañamos', desc: 'Garantía y soporte después de la entrega. No desaparecemos.' },
];

const clientes = [
  { nombre: 'Toyota',          logo: '/logos/toyota-seeklogo.svg' },
  { nombre: 'TaskUs',          logo: '/logos/taskus-seeklogo.png' },
  { nombre: 'Bavaria',         logo: '/logos/bavaria.png' },
  { nombre: 'Corona Colombia', logo: '/logos/Corona Colombia.svg' },
  { nombre: 'Ecopetrol',       logo: '/logos/Ecopetrol_Logo_0.svg' },
  { nombre: 'Motul',           logo: '/logos/motul-logo-1.svg' },
];

const WA_COTIZAR = `https://wa.me/573000000000?text=${encodeURIComponent('Hola, quiero cotizar un proyecto con Kiel.')}`;
---

<Layout title="Mobiliario corporativo y carpintería arquitectónica en Cali">

  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section class="relative min-h-screen overflow-hidden flex items-center justify-center pt-16">

    <!-- Slides de fondo -->
    {heroSlides.map((slide) => (
      <div
        class="hero-slide"
        style={`background-image: url('${slide.src}')`}
        role="img"
        aria-label={slide.alt}
      />
    ))}

    <!-- Overlay gradiente oscuro -->
    <div
      class="absolute inset-0 z-10"
      style="background: linear-gradient(to bottom, rgba(0,8,20,0.62) 0%, rgba(0,8,20,0.38) 45%, rgba(0,8,20,0.72) 100%)"
    ></div>

    <!-- Contenido centrado -->
    <div class="relative z-20 text-center max-w-4xl mx-auto px-6 py-28">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 backdrop-blur-sm rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 rounded-full bg-kiel-orange shrink-0 animate-pulse"></span>
        <span class="text-white text-xs font-semibold tracking-wide">Fabricamos en Cali y Palmira · Servicio en todo Colombia</span>
      </div>

      <h1 class="font-serif text-white text-5xl sm:text-6xl lg:text-7xl leading-tight mb-6">
        Creamos espacios que sí funcionan.
      </h1>

      <p class="text-white/70 text-xl leading-relaxed mb-10 max-w-2xl mx-auto">
        Diseñamos, fabricamos e instalamos mobiliario y carpintería arquitectónica para empresas, colegios y proyectos en Colombia.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
        <a
          href="#cotizar"
          class="inline-flex items-center gap-2 bg-kiel-orange hover:bg-kiel-orange-dark text-white font-bold px-8 py-4 rounded-xl transition-colors text-base shadow-2xl shadow-orange-900/40"
        >
          Cotiza gratis ahora
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <span class="text-white/55 text-sm flex items-center gap-2">
          <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Te respondemos de inmediato
        </span>
      </div>
    </div>

    <!-- Indicadores de slide -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex gap-2">
      {heroSlides.map((_, i) => (
        <div class="hero-dot" style={`animation-delay: ${i * 6}s`}></div>
      ))}
    </div>

    <!-- Flecha scroll -->
    <div class="absolute bottom-8 right-8 z-20 hidden sm:flex flex-col items-center gap-1.5 text-white/30">
      <span class="text-[10px] tracking-[0.2em] uppercase rotate-90 origin-center translate-y-3">Scroll</span>
      <svg class="w-4 h-4 animate-bounce mt-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════ FORMULARIO ═══════════════════════ -->
  <section id="cotizar" class="bg-slate-50 py-24 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid lg:grid-cols-2 gap-16 items-start">

      <!-- Izquierda: texto (abajo en móvil, izquierda en desktop) -->
      <div class="lg:pt-4 order-2 lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-widest text-kiel-orange mb-4">Cotización sin costo</p>
        <h2 class="font-serif text-2xl sm:text-3xl text-slate-900 mb-5 leading-snug">
          Cuéntanos un poco más: ¿qué espacio quieres transformar y qué te gustaría lograr?
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed mb-10">
          Cuéntanos qué necesitas y te contactaremos de inmediato. Sin compromiso.
        </p>

        <div class="space-y-5">
          {[
            { icon: '🏢', titulo: '28 años de experiencia', desc: 'Mobiliario corporativo, educativo e institucional para Colombia.' },
            { icon: '⚡', titulo: 'Respuesta en menos de 24h', desc: 'Te contactamos el mismo día hábil.' },
            { icon: '🏭', titulo: 'Fabricación propia', desc: 'Planta propia en Palmira, Valle del Cauca. Control total.' },
          ].map((item) => (
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl bg-white border border-slate-100 shadow-sm flex items-center justify-center text-lg shrink-0">
                {item.icon}
              </div>
              <div>
                <p class="font-semibold text-slate-800 text-sm">{item.titulo}</p>
                <p class="text-slate-400 text-sm">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Derecha: formulario (primero en móvil, derecha en desktop) -->
      <div class="bg-white rounded-2xl shadow-md border-2 border-kiel-blue p-8 order-1 lg:order-2">
        <form id="cotizar-form" novalidate>
          <input type="hidden" id="necesidad-input" name="necesidad" />

          <!-- Indicador de progreso -->
          <div class="flex items-center gap-1.5 mb-6">
            <div class="prog-pill done" id="p1"></div>
            <div class="prog-pill" id="p2"></div>
            <div class="prog-pill" id="p3"></div>
            <span class="ml-2 text-xs text-slate-400 font-medium">
              Paso <span id="step-current">1</span> de 3
            </span>
          </div>

          <!-- ── PASO 1: ¿Qué necesitas? ── -->
          <div id="step-1">
            <p class="font-semibold text-slate-800 text-sm mb-0.5">¿Qué necesitas?</p>
            <p class="text-xs text-slate-400 mb-3">Selecciona una opción para continuar.</p>
            <div class="grid grid-cols-2 gap-2 mb-5">
              {chipOpciones.map((c) => (
                <button type="button" class="chip" data-value={c.label}>
                  <span class="chip-icon">
                    <Fragment set:html={c.icon} />
                  </span>
                  <span>{c.label}</span>
                </button>
              ))}
            </div>
            <button
              type="button"
              id="btn-next-1"
              disabled
              class="w-full bg-kiel-orange hover:bg-kiel-orange-dark disabled:opacity-35 disabled:cursor-not-allowed text-white font-semibold py-3 rounded-lg transition-colors text-sm flex items-center justify-center gap-2"
            >
              Continuar
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </button>
          </div>

          <!-- ── PASO 2: Tu proyecto ── -->
          <div id="step-2" class="hidden">
            <p class="font-semibold text-slate-800 text-sm mb-1">Cuéntanos sobre tu proyecto</p>
            <div class="flex items-center gap-2 mb-3 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
              <svg class="w-4 h-4 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
              </svg>
              <p class="text-xs text-amber-700 font-medium">Opcional — nos ayuda a preparar una mejor propuesta.</p>
            </div>
            <textarea
              name="descripcion"
              rows="5"
              placeholder="¿Qué espacio quieres transformar? ¿Qué te gustaría lograr?"
              class="form-input resize-none mb-4"
            ></textarea>
            <div class="flex gap-2">
              <button type="button" id="btn-back-2"
                class="flex-1 border border-slate-200 text-slate-500 hover:bg-slate-100 font-medium py-3 rounded-lg transition-colors text-sm">
                ← Atrás
              </button>
              <button type="button" id="btn-next-2"
                class="flex-2 bg-kiel-orange hover:bg-kiel-orange-dark text-white font-semibold py-3 rounded-lg transition-colors text-sm flex items-center justify-center gap-2">
                Continuar
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </button>
            </div>
          </div>

          <!-- ── PASO 3: Tus datos ── -->
          <div id="step-3" class="hidden">
            <p class="font-semibold text-slate-800 text-sm mb-1">Tus datos de contacto</p>
            <p class="text-xs text-slate-400 mb-4">Te contactamos en menos de 24 horas.</p>
            <div class="space-y-2 mb-4">
              <input type="text"  name="nombre"   required placeholder="Nombre completo *"       class="form-input" />
              <input type="text"  name="empresa"  required placeholder="Empresa / institución *" class="form-input" />
              <input type="tel"   name="telefono" required placeholder="Teléfono / WhatsApp *"    class="form-input" />
              <input type="text"  name="cargo"             placeholder="Cargo"                    class="form-input" />
              <input type="email" name="correo"            placeholder="Correo electrónico"       class="form-input" />
            </div>
            <div class="flex gap-2">
              <button type="button" id="btn-back-3"
                class="flex-1 border border-slate-200 text-slate-500 hover:bg-slate-100 font-medium py-3 rounded-lg transition-colors text-sm">
                ← Atrás
              </button>
              <button type="submit" id="submit-btn"
                class="flex-2 bg-kiel-orange hover:bg-kiel-orange-dark disabled:opacity-60 text-white font-semibold py-3 rounded-lg transition-colors text-sm">
                Quiero que me contacten
              </button>
            </div>
          </div>

          <div id="form-success" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-xl text-sm text-green-800">
            ¡Listo! Recibimos tu información, nuestro equipo te contactará muy pronto.
          </div>
          <div id="form-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-800">
            Ocurrió un error al enviar. Intenta de nuevo o escríbenos por WhatsApp.
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ SERVICIOS ═══════════════════════ -->
  <section class="bg-gray-100 py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      <!-- Título centrado -->
      <div class="text-center mx-auto mb-14">
        <p class="text-xs font-semibold uppercase tracking-widest text-kiel-orange mb-4">Nuestros servicios</p>
        <h2 class="font-serif text-4xl sm:text-5xl text-slate-900 mb-4 whitespace-nowrap">
          ¿Qué proyecto tienes en mente?
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed">
          Encontraremos la solución adecuada para hacerlo realidad.
        </p>
      </div>

      <!-- Grid 3×2 -->
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-5">

        {servicios.map((s, i) => (
          <a
            href={s.href}
            class="group relative overflow-hidden rounded-2xl h-56 sm:h-64 lg:h-80 block"
          >
            <!-- Imagen full-bleed -->
            <img
              src={s.img}
              alt={s.titulo}
              class="service-img"
              loading="lazy"
            />

            <!-- Gradiente permanente -->
            <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/15 to-transparent pointer-events-none" />

            <!-- Número (top-left) -->
            <span class="absolute top-4 left-4 font-serif text-white/35 text-xs tracking-widest select-none">
              {String(i + 1).padStart(2, '0')}
            </span>

            <!-- Ícono (top-right) -->
            <div class="absolute top-3 right-3 w-8 h-8 rounded-lg bg-black/30 backdrop-blur-sm flex items-center justify-center text-white/50 group-hover:bg-kiel-orange group-hover:text-white transition-all duration-300">
              <Fragment set:html={s.icon} />
            </div>

            <!-- Info (bottom, crece hacia arriba al hover) -->
