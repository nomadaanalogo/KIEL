---
import Layout from '../layouts/Layout.astro';

const catalogos = [
  {
    nombre: 'Oficinas',
    desc: 'Soluciones de mobiliario y adecuación para espacios corporativos y de trabajo.',
    archivo: '/catalogos/1-CATALOGO OFICINA.pdf',
    acento: '#0065AD',
    bg: '#EFF6FF',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>`,
  },
  {
    nombre: 'Educación',
    desc: 'Mobiliario y carpintería para colegios, universidades y centros de formación.',
    archivo: '/catalogos/2-CATALOGO EDUCACION.pdf',
    acento: '#059669',
    bg: '#ECFDF5',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>`,
  },
  {
    nombre: 'Colectividades y zonas comunes',
    desc: 'Mobiliario para espacios de uso colectivo: comedores, zonas comunes y áreas sociales.',
    archivo: '/catalogos/3-CATALOGO COLECTIVIDADES.pdf',
    acento: '#7C3AED',
    bg: '#F5F3FF',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
  },
  {
    nombre: 'Almacenamiento',
    desc: 'Sistemas modulares para bodegas, archivos y puntos de venta.',
    archivo: '/catalogos/4-CATALOGO ALMACENAMIENTO.pdf',
    acento: '#D97706',
    bg: '#FFFBEB',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>`,
  },
  {
    nombre: 'Carpintería arquitectónica',
    desc: 'Fabricación a medida de elementos en madera para arquitectura e interiorismo.',
    archivo: '/catalogos/5-CATALOGO CARPINTERIA ARQ_.pdf',
    acento: '#92400E',
    bg: '#FDF8F4',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852z"/></svg>`,
  },
];
---

<Layout
  title="Catálogos de Mobiliario para Oficinas y Colegios"
  description="Descarga los catálogos de Kiel: mobiliario para oficinas, educación, almacenamiento y carpintería arquitectónica. Fabricación colombiana."
>

  <!-- ════════════════ HERO ════════════════ -->
  <section class="bg-slate-950 pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="max-w-4xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-5">
        <div class="w-8 h-px bg-kiel-orange"></div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-kiel-orange">Descarga gratis</p>
      </div>
      <h1 class="font-serif text-4xl sm:text-6xl text-white leading-[1.08] mb-4">
        Catálogos de mobiliario corporativo, educativo y carpintería
      </h1>
      <p class="text-white/50 text-lg leading-relaxed">
        Encuentra la solución ideal para tu espacio en nuestras líneas de producto.
      </p>
    </div>
  </section>

  <!-- ════════════════ CATÁLOGOS ════════════════ -->
  <section class="bg-gray-50 py-14 sm:py-20">
    <div class="max-w-4xl mx-auto px-6 sm:px-10 flex flex-col gap-4">
      {catalogos.map(cat => (
        <div class="group bg-white rounded-2xl border border-slate-100 hover:border-slate-200 hover:shadow-md transition-all duration-300 flex items-center gap-6 p-6">

          <!-- Ícono -->
          <div class="shrink-0 -rotate-12 [&>svg]:w-10 [&>svg]:h-10" style={`color:${cat.acento}`}>
            <Fragment set:html={cat.icon} />
          </div>

          <!-- Texto -->
          <div class="flex-1 min-w-0">
            <h2 class="font-semibold text-slate-900 text-base mb-1">{cat.nombre}</h2>
            <p class="text-slate-500 text-sm leading-relaxed">{cat.desc}</p>
          </div>

          <!-- Botón -->
          <a
            href={cat.archivo}
            download
            class="shrink-0 inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors text-white"
            style={`background:${cat.acento}`}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
            <span class="hidden sm:inline">Descargar</span>
          </a>

        </div>
      ))}
    </div>
  </section>

</Layout>
