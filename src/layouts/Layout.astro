---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logoKiel from '../assets/LogoKiel.jpg';

interface Props {
  title: string;
  description?: string;
  cotizarHref?: string;
  ogImage?: string;
  noindex?: boolean;
}

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const {
  title,
  description = 'Kiel — Fabricante de mobiliario corporativo, educativo e institucional en Cali y Palmira, Colombia. Diseño, producción e instalación de espacios integrales.',
  cotizarHref = '/#cotizar',
  ogImage = '/og-kiel.jpg',
  noindex = false,
} = Astro.props;

const SITE_URL = 'https://www.kiel.com.co';
const canonicalURL = new URL(currentPath, SITE_URL).href;
const ogImageURL = new URL(ogImage, SITE_URL).href;
const fullTitle = currentPath === '/' ? 'Kiel | Mobiliario Corporativo, Educativo y Carpintería en Cali y Palmira' : `${title} | Kiel`;

const WA_NUMBER = '573000000000';
const WA_MENSAJE = encodeURIComponent('Hola, quiero cotizar un proyecto con Kiel.');
const WA_HREF = `https://wa.me/${WA_NUMBER}?text=${WA_MENSAJE}`;
const TEL = '+57 300 000 0000';
const TEL_HREF = 'tel:+573000000000';

const navLinks = [
  {
    label: 'Home',
    href: '/',
    icon: `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`,
  },
  {
    label: 'Nosotros',
    href: '/nosotros',
    icon: `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
  },
  {
    label: 'Servicios',
    href: '/servicios',
    icon: `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" /></svg>`,
  },
  {
    label: 'Casos',
    href: '/casos',
    icon: `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" /></svg>`,
  },
  {
    label: 'Catálogos',
    href: '/catalogos',
    icon: `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
  },
  {
    label: 'Blog',
    href: '/blog',
    icon: `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" /></svg>`,
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="mobiliario corporativo Cali, mobiliario para oficinas Cali, mobiliario educativo Colombia, carpintería arquitectónica Cali, fabricante mobiliario Palmira, adecuación de oficinas, diseño de espacios corporativos, muebles de oficina Colombia, mobiliario institucional, escritorios para oficinas, sillas para oficinas, divisiones modulares, sala de juntas, puestos de trabajo, mobiliario para colegios" />
    <meta name="author" content="Kiel" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Kiel" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD: LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Kiel",
      "description": "Fabricante colombiano de mobiliario corporativo, educativo e institucional. Diseño, producción e instalación de espacios en Cali, Palmira y todo Colombia.",
      "url": SITE_URL,
      "telephone": "+573000000000",
      "email": "info@kiel.com.co",
      "foundingDate": "1996",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Palmira",
        "addressRegion": "Valle del Cauca",
        "addressCountry": "CO"
      },
      "areaServed": [
        { "@type": "City", "name": "Cali" },
        { "@type": "City", "name": "Palmira" },
        { "@type": "Country", "name": "Colombia" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Catálogo de servicios Kiel",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mobiliario corporativo y adecuación de oficinas" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mobiliario educativo para colegios y universidades" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Carpintería arquitectónica a medida" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mobiliario institucional y colectivo" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sistemas de almacenamiento" } }
        ]
      },
      "sameAs": []
    })} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Fredoka:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="font-sans text-slate-900 bg-white">

    <!-- ═══════════════════════ NAVBAR ═══════════════════════ -->
    <header class="fixed top-0 inset-x-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">

        <a href="/" class="shrink-0">
          <Image src={logoKiel} alt="Kiel — Fabricamos diseño" height={38} class="h-9 w-auto" />
        </a>

        <!-- Desktop links -->
        <ul class="hidden md:flex items-center gap-6">
          {navLinks.map(({ label, href, icon }) => {
            const active = isActive(href);
            return (
              <li>
                <a
                  href={href}
                  class={`flex items-center gap-1.5 text-sm font-medium transition-colors group ${active ? 'text-slate-900' : 'text-slate-500 hover:text-slate-900'}`}
                >
                  <span class={`transition-colors ${active ? 'text-kiel-orange' : 'text-slate-400 group-hover:text-kiel-orange'}`}>
                    <Fragment set:html={icon} />
                  </span>
                  {label}
                  {active && <span class="sr-only">(página actual)</span>}
                </a>
                {active && <div class="h-0.5 bg-kiel-orange rounded-full mt-0.5 mx-auto" style="width:80%"></div>}
              </li>
            );
          })}
        </ul>

        <!-- Desktop CTAs -->
        <div class="hidden md:flex items-center gap-3 shrink-0">
          <a href={TEL_HREF} class="flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-900 transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
            </svg>
            {TEL}
          </a>
          <a href={cotizarHref} class="bg-kiel-orange hover:bg-kiel-orange-dark text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Cotizar proyecto
          </a>
        </div>

        <!-- Hamburger -->
        <button
          id="menu-btn"
          class="md:hidden p-2 -mr-2 rounded-lg text-slate-700 hover:bg-slate-100 transition-colors"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg id="icon-burger" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-x" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white">
        <ul class="px-4 py-3 flex flex-col gap-0.5">
          {navLinks.map(({ label, href, icon }) => (
            <li>
              <a href={href} class="flex items-center gap-2.5 px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 rounded-lg transition-colors group">
                <span class="text-slate-400 group-hover:text-kiel-orange transition-colors">
                  <Fragment set:html={icon} />
                </span>
                {label}
              </a>
            </li>
          ))}
        </ul>
        <div class="px-4 pb-4 pt-2 border-t border-slate-100 flex flex-col gap-2">
          <a href={TEL_HREF} class="flex items-center gap-2 px-3 py-2 text-sm text-slate-500">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
            </svg>
            {TEL}
          </a>
          <a href={cotizarHref} class="flex justify-center bg-kiel-orange hover:bg-kiel-orange-dark text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors">
            Cotizar proyecto
          </a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ═══════════════════════ FOOTER ═══════════════════════ -->
    <footer class="bg-slate-950 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-10">

          <!-- Brand -->
          <div class="lg:col-span-4">
            <div class="mb-4">
              <Image src={logoKiel} alt="Kiel" height={44} class="h-11 w-auto" />
            </div>
            <p class="text-slate-400 text-sm leading-relaxed max-w-xs">
              28 años diseñando, fabricando y construyendo espacios que sí funcionan.
            </p>
            <div class="flex gap-4 mt-6">
              <a href="#" class="text-slate-400 hover:text-white transition-colors" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
              <a href="#" class="text-slate-400 hover:text-white transition-colors" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Sitemap -->
          <div class="lg:col-span-2">
            <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Páginas</h4>
            <ul class="space-y-2.5">
              {navLinks.map(({ label, href }) => (
                <li>
                  <a href={href} class="text-slate-400 text-sm hover:text-white transition-colors">{label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Servicios -->
          <div class="lg:col-span-3">
            <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Servicios</h4>
            <ul class="space-y-2.5">
              <li><a href="/servicios#corporativos" class="text-slate-400 text-sm hover:text-white transition-colors">Espacios corporativos</a></li>
              <li><a href="/servicios#educativos" class="text-slate-400 text-sm hover:text-white transition-colors">Espacios educativos</a></li>
              <li><a href="/servicios#carpinteria" class="text-slate-400 text-sm hover:text-white transition-colors">Carpintería arquitectónica</a></li>
              <li><a href="/servicios#institucional" class="text-slate-400 text-sm hover:text-white transition-colors">Mobiliario institucional</a></li>
              <li><a href="/servicios#almacenamiento" class="text-slate-400 text-sm hover:text-white transition-colors">Almacenamiento</a></li>
            </ul>
          </div>

          <!-- Contacto -->
          <div class="lg:col-span-3">
            <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Contacto</h4>
            <ul class="space-y-2.5 text-slate-400 text-sm">
              <li><a href={TEL_HREF} class="hover:text-white transition-colors">{TEL}</a></li>
              <li><a href="mailto:info@kiel.com.co" class="hover:text-white transition-colors">info@kiel.com.co</a></li>
              <li>Cali, Colombia</li>
            </ul>
          </div>
        </div>

        <!-- Google Maps -->
        <div class="mt-12 rounded-xl overflow-hidden border border-slate-800 h-48">
          <!-- Reemplaza el src con tu enlace de Google Maps → Maps > Compartir > Incorporar mapa -->
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d254508.38716318!2d-76.65185!3d3.4516!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e30a6f0e3e3e3e3%3A0x0!2sCali%2C+Colombia!5e0!3m2!1ses!2sco!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación Kiel en Cali"
          ></iframe>
        </div>

        <div class="border-t border-slate-800 mt-8 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-slate-600 text-xs">
          <span>© {new Date().getFullYear()} Kiel. Todos los derechos reservados.</span>
          <span class="text-center sm:text-right">Kiel — 28 años diseñando, fabricando y construyendo espacios.</span>
        </div>
      </div>
    </footer>

    <!-- WhatsApp flotante -->
    <a
      href={WA_HREF}
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-green-500 hover:bg-green-600 rounded-full shadow-xl transition-all hover:scale-105"
      aria-label="Contactar por WhatsApp"
    >
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
